# Copy to .env and fill in. If ANTHROPIC_API_KEY is absent, the reasoning engine
# runs in deterministic offline-fallback mode (no LLM calls, no cost).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
# Complex agents (RCA, CAPA, Incident) can optionally use a stronger model:
CLAUDE_MODEL_COMPLEX=claude-opus-4-6

# Auto-start the orchestrator on boot so the simulator runs continuously and keeps
# appending to autoagent.db (~150 MB/day). Leave false to start it manually from the UI.
ORCH_AUTOSTART=false
ORCH_AUTOSTART_MODE=DETERMINISTIC
